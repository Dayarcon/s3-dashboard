# Top-level .env.example for docker-compose. Copy to .env and edit.
# Compose uses ${VAR} substitutions in docker-compose.yml.

# REQUIRED
JWT_SECRET=

# Initial admin user (created on first startup if not present).
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=

# AWS (alternative: mount ~/.aws or use IAM role on the host)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Origins permitted to call the backend. When using the bundled nginx,
# requests to /api are same-origin so this can be your public URL.
CORS_ALLOWLIST=http://localhost

# Tunables
JWT_EXPIRES_IN=1h
LOG_LEVEL=info
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_MAX=10
MIN_PASSWORD_LENGTH=8
REQUIRE_PASSWORD_COMPLEXITY=true
PUBLIC_SIGNUP_ENABLED=false
HTTP_PORT=80

# Frontend: leave blank to use same-origin via nginx, or set to a full URL.
NEXT_PUBLIC_BACKEND_URL=
