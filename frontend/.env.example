# Frontend env. Copy to frontend/.env. Do NOT commit secrets.
#
# All NEXT_PUBLIC_* values are inlined at build time and shipped to the
# browser. Never put secrets here.

# Public-facing URL of the backend.
# - Local dev (Next.js + backend on host): http://localhost:4000
# - Behind nginx in docker-compose: leave blank to use same-origin
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Public-facing URL of the frontend app (used for building invite links)
# - Local dev: http://localhost:3000
# - Production: https://app.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
