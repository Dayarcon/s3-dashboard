# Backend env. Copy to backend/.env and edit. Do NOT commit secrets.

# ---- environment & runtime ----
NODE_ENV=development                 # production | development | test
PORT=4000
LOG_LEVEL=debug                       # trace | debug | info | warn | error
DATA_DIR=                             # absolute path; defaults to backend/data

# ---- auth (REQUIRED) ----
# Strong random secret. In production, startup will fail if missing or set to
# the placeholder "change-me". Generate with: openssl rand -hex 32
JWT_SECRET=change-me
JWT_EXPIRES_IN=1h

# ---- super admin bootstrap (optional) ----
# If set, the user is created on first startup. Use a strong password.
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_PASSWORD=

# ---- CORS ----
# Comma-separated allowlist of origins permitted to call the API.
# In production, startup fails if this is empty.
# Example: https://app.example.com,https://staging.example.com
CORS_ALLOWLIST=http://localhost:3000

# ---- rate limits ----
RATE_LIMIT_WINDOW_MS=60000           # global window in ms
RATE_LIMIT_MAX=300                   # requests per window per IP
LOGIN_RATE_LIMIT_WINDOW_MS=900000    # 15 min
LOGIN_RATE_LIMIT_MAX=10              # login requests per window per IP

# ---- account lockout (login failures) ----
LOGIN_MAX_FAILURES=5
LOGIN_FAILURE_WINDOW_MS=900000       # 15 min
LOGIN_LOCKOUT_MS=900000              # 15 min

# ---- password policy ----
MIN_PASSWORD_LENGTH=8
REQUIRE_PASSWORD_COMPLEXITY=true     # require lowercase + uppercase + digit
BCRYPT_ROUNDS=12

# ---- features ----
PUBLIC_SIGNUP_ENABLED=false          # /auth/signup is admin-only by default
JSON_BODY_LIMIT=5mb
UPLOAD_MAX_BYTES=26214400            # single-shot upload cap (25 MB)

# ---- AWS / S3 ----
AWS_REGION=ap-south-1
# AWS credentials should come from the standard provider chain
# (env vars AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY, IAM role, ~/.aws/credentials, etc.)
BUCKET_LOCATION_TTL_MS=3600000       # cache TTL for GetBucketLocation, default 1h
